{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["uid", "email"]
    },
    "Service": {
      "title": "Service",
      "description": "Available services offered by Tendr",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["lawn", "decks", "rubbish"] },
        "basePrice": { "type": "number" }
      },
      "required": ["id", "name", "category"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "serviceType": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "date", "address", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available services"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    }
  }
}
